{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Demo 3: A/B Testing & Uplift Modeling\n",
    "\n",
    "This notebook demonstrates:\n",
    "1. **Frequentist A/B testing** — t-tests, proportion tests, sequential testing\n",
    "2. **Bayesian A/B testing** — Beta-Binomial, Normal-Normal, ROPE, expected loss\n",
    "3. **Power analysis & sample size calculation**\n",
    "4. **Uplift modeling** — T-learner, S-learner, X-learner, Causal Forest, DR-learner\n",
    "5. **Uplift evaluation** — Qini curve, AUUC, gain/decile charts\n",
    "6. **Multiple testing corrections** — Bonferroni, Benjamini-Hochberg"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Causal Toolkit\n",
    "from causal_toolkit.analysis.ab_test import (\n",
    "    ABTestAnalyzer, ABTestData, ABTestResult,\n",
    "    TestType, Alternative, evaluate_uplift\n",
    ")\n",
    "from causal_toolkit.wrappers.econml import UpliftModeler\n",
    "from causal_toolkit.visualization.plots import UpliftPlot\n",
    "from causal_toolkit.utils.data import load_dataset, create_synthetic_data\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "sns.set_palette('husl')\n",
    "np.random.seed(42)\n",
    "\n",
    "print(\"Imports successful\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Synthetic A/B Test Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate synthetic A/B test data\n",
    "n_users = 20000\n",
    "baseline_rate = 0.10  # 10% conversion\n",
    "treatment_lift = 0.05  # 5% relative lift\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "# Assign variants\n",
    "variant = np.random.choice(['A', 'B'], n_users, p=[0.5, 0.5])\n",
    "\n",
    "# Conversion probabilities\n",
    "p_convert = np.where(variant == 'A',\n",
    "                     baseline_rate,\n",
    "                     baseline_rate * (1 + treatment_lift))\n",
    "\n",
    "# Simulate conversions\n",
    "converted = np.random.binomial(1, p_convert)\n",
    "\n",
    "# Revenue per user (for revenue metric)\n",
    "revenue = np.where(converted == 1,\n",
    "                   np.random.exponential(50, n_users),\n",
    "                   0)\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    'user_id': range(n_users),\n",
    "    'variant': variant,\n",
    "    'converted': converted,\n",
    "    'revenue': revenue,\n",
    "})\n",
    "\n",
    "print(f\"Total users: {len(df)}\")\n",
    "print(f\"Variant A: {(variant=='A').sum()}, B: {(variant=='B').sum()}\")\n",
    "print(f\"Conversion A: {df[df['variant']=='A']['converted'].mean():.3%}\")\n",
    "print(f\"Conversion B: {df[df['variant']=='B']['converted'].mean():.3%}\")\n",
    "print(f\"Revenue A: ${df[df['variant']=='A']['revenue'].mean():.2f}\")\n",
    "print(f\"Revenue B: ${df[df['variant']=='B']['revenue'].mean():.2f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Frequentist A/B Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "analyzer = ABTestAnalyzer(confidence_level=0.95)\n",
    "\n",
    "# Prepare data\n",
    "ab_data = analyzer.from_dataframe(\n",
    "    df, variant_col='variant', outcome_col='converted',\n",
    "    variant_a='A', variant_b='B',\n",
    "    test_type=TestType.PROPORTION\n",
    ")\n",
    "\n",
    "# Frequentist proportion z-test\n",
    "result_freq = analyzer.analyze(ab_data, TestType.PROPORTION, 'frequentist')\n",
    "print(result_freq)\n",
    "\n",
    "# Also test for mean revenue\n",
    "ab_data_rev = analyzer.from_dataframe(\n",
    "    df, variant_col='variant', outcome_col='revenue',\n",
    "    variant_a='A', variant_b='B',\n",
    "    test_type=TestType.MEAN\n",
    ")\n",
    "result_rev = analyzer.analyze(ab_data_rev, TestType.MEAN, 'frequentist')\n",
    "print(result_rev)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Bayesian A/B Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Bayesian Beta-Binomial\n",
    "result_bayes = analyzer.analyze(ab_data, TestType.PROPORTION, 'bayesian',\n",
    "                                 prior_alpha=1, prior_beta=1, rope_width=0.005)\n",
    "print(result_bayes)\n",
    "\n",
    "# Interpretation:\n",
    "print(f\"\\nProbability B > A: {result_bayes.prob_b_better:.2%}\")\n",
    "print(f\"ROPE probability (practically equivalent): {result_bayes.rope_probability:.2%}\")\n",
    "print(f\"Expected loss if choose A: {result_bayes.expected_loss_a:.6f}\")\n",
    "print(f\"Expected loss if choose B: {result_bayes.expected_loss_b:.6f}\")\n",
    "\n",
    "if result_bayes.prob_b_better > 0.95:\n",
    "    print(\"\\n✓ DECISION: Launch variant B\")\n",
    "elif result_bayes.rope_probability > 0.8:\n",
    "    print(\"\\n= DECISION: No meaningful difference\")\n",
    "else:\n",
    "    print(\"\\n? DECISION: Inconclusive, continue experiment\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Sequential Testing (Optional Stopping)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SPRT - Sequential Probability Ratio Test\n",
    "sprt_result = analyzer.sprt(ab_data, mde=0.05, alpha=0.05, beta=0.2)\n",
    "print(f\"SPRT Decision: {sprt_result['decision']}\")\n",
    "print(f\"LLR: {sprt_result['llr']:.3f}\")\n",
    "print(f\"Bounds: [{sprt_result['lower_bound']:.3f}, {sprt_result['upper_bound']:.3f}]\")\n",
    "\n",
    "# mSPRT - Mixture SPRT (Bayesian sequential)\n",
    "msprt_result = analyzer.msprt(ab_data, mde=0.05, alpha=0.05)\n",
    "print(f\"\\nmSPRT Decision: {msprt_result['decision']}\")\n",
    "print(f\"Bayes Factor: {msprt_result['bayes_factor']:.3f}\")\n",
    "print(f\"Threshold: {msprt_result['threshold']:.3f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Power Analysis & Sample Size"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate required sample size\n",
    "power_result = analyzer.power_analysis(\n",
    "    baseline_rate=0.10,\n",
    "    mde=0.05,  # 5% relative lift\n",
    "    alpha=0.05,\n",
    "    power=0.80,\n",
    "    ratio=1.0\n",
    ")\n",
    "print(f\"Sample per variant: {power_result['sample_size_per_variant']:,}\")\n",
    "print(f\"Total sample: {power_result['total_sample_size']:,}\")\n",
    "print(f\"Effect size (Cohen's h): {power_result['effect_size']:.4f}\")\n",
    "print(f\"Achieved power: {power_result['achieved_power']:.4f}\")\n",
    "\n",
    "# What MDE can we detect with current sample?\n",
    "mde = analyzer.mde_calculation(0.10, 10000, 0.05, 0.8)\n",
    "print(f\"\\nWith n=10000 per variant, MDE = {mde:.2%} relative\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Multiple Testing Correction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate multiple variants tested\n",
    "np.random.seed(42)\n",
    "k = 10  # 10 variants vs control\n",
    "p_values = []\n",
    "\n",
    "for i in range(k):\n",
    "    variant_convert = np.random.choice([0, 1], 1000, p=[0.9, 0.1])\n",
    "    # One variant has real effect\n",
    "    if i == 3:\n",
    "        variant_convert = np.random.choice([0, 1], 1000, p=[0.85, 0.15])\n",
    "    \n",
    "    control_convert = np.random.choice([0, 1], 1000, p=[0.9, 0.1])\n",
    "    from statsmodels.stats.proportion import proportions_ztest\n",
    "    count = np.array([variant_convert.sum(), control_convert.sum()])\n",
    "    nobs = np.array([1000, 1000])\n",
    "    _, p = proportions_ztest(count, nobs)\n",
    "    p_values.append(p)\n",
    "\n",
    "print(f\"Raw p-values: {np.array(p_values).round(4)}\")\n",
    "\n",
    "# Bonferroni\n",
    "bonf = analyzer.bonferroni_correction(p_values, alpha=0.05)\n",
    "print(f\"\\nBonferroni (α={bonf['adjusted_alpha']:.5f}):\")\n",
    "for i, (p, adj) in enumerate(zip(bonf['rejected'], bonf['adjusted_p_values'])):\n",
    "    print(f\"  Variant {i}: p={p_values[i]:.4f}, adj={adj:.4f}, reject={p}\")\n",
    "\n",
    "# Benjamini-Hochberg\n",
    "bh = analyzer.benjamini_hochberg(p_values, alpha=0.05)\n",
    "print(f\"\\nBenjamini-Hochberg (FDR=0.05):\")\n",
    "for i, r in enumerate(bh['rejected']):\n",
    "    print(f\"  Variant {i}: p={p_values[i]:.4f}, adj={bh['adjusted_p_values'][i]:.4f}, reject={r}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Uplift Modeling on Criteo Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load Criteo uplift benchmark (synthetic for demo)\n",
    "df_uplift = load_dataset('criteo_uplift')\n",
    "print(f\"Criteo Uplift: {df_uplift.shape}\")\n",
    "print(f\"Treatment rate: {df_uplift['treatment'].mean():.2%}\")\n",
    "print(f\"Outcome mean: {df_uplift['outcome'].mean():.4f}\")\n",
    "print(f\"True CATE mean: {df_uplift['true_cate'].mean():.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Split train/test\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "features = [c for c in df_uplift.columns if c.startswith('feature')]\n",
    "\n",
    "train, test = train_test_split(df_uplift, test_size=0.3, random_state=42)\n",
    "\n",
    "X_train = train[features].values\n",
    "T_train = train['treatment'].values\n",
    "Y_train = train['outcome'].values\n",
    "\n",
    "X_test = test[features].values\n",
    "T_test = test['treatment'].values\n",
    "Y_test = test['outcome'].values\n",
    "true_cate = test['true_cate'].values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fit multiple uplift models\n",
    "models = {}\n",
    "uplift_preds = {}\n",
    "metrics = {}\n",
    "\n",
    "for name in ['causal_forest', 'two_model', 'dr_learner']:\n",
    "    print(f\"\\nFitting {name}...\")\n",
    "    uplift_modeler = UpliftModeler(train, 'treatment', 'outcome', features)\n",
    "    uplift_modeler.fit(method=name)\n",
    "    models[name] = uplift_modeler\n",
    "    \n    # Predict on test\n",
    "    uplift = uplift_modeler.predict_uplift(X_test)\n",
    "    uplift_preds[name] = uplift\n",
    "    \n    # Evaluate\n",
    "    m = uplift_modeler.evaluate(X_test, T_test, Y_test)\n",
    "    metrics[name] = m\n",
    "    print(f\"  Qini: {m['qini']:.4f}, AUUC: {m['auuc']:.4f}\")\n",
    "    print(f\"  Mean uplift: {m['uplift_mean']:.4f}, Std: {m['uplift_std']:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Qini curves comparison\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "\n",
    "for i, (name, uplift) in enumerate(uplift_preds.items()):\n",
    "    UpliftPlot().plot_qini(uplift, T_test, Y_test, n_bins=10)\n",
    "    axes[i].set_title(f'{name} — Qini Curve')\n",
    "    axes[i].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Gain/Decile charts\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "\n",
    "for i, (name, uplift) in enumerate(uplift_preds.items()):\n",
    "    UpliftPlot().plot_gain(uplift, T_test, Y_test, n_bins=10)\n",
    "    axes[i].set_title(f'{name} — Gain by Decile')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Uplift vs True CATE correlation\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "\n",
    "for i, (name, uplift) in enumerate(uplift_preds.items()):\n",
    "    axes[i].scatter(true_cate, uplift, alpha=0.3, s=1)\n",
    "    axes[i].plot([true_cate.min(), true_cate.max()],\n",
    "                [true_cate.min(), true_cate.max()], 'r--')\n",
    "    axes[i].set_xlabel('True CATE')\n",
    "    axes[i].set_ylabel('Predicted Uplift')\n",
    "    axes[i].set_title(f'{name}\nCorr = {np.corrcoef(true_cate, uplift)[0,1]:.3f}')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CATE distributions\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "\n",
    "for i, (name, uplift) in enumerate(uplift_preds.items()):\n",
    "    axes[i].hist(uplift, bins=50, alpha=0.7, density=True, edgecolor='black')\n",
    "    axes[i].axvline(np.mean(uplift), color='red', linestyle='--',\n",
    "               label=f'Mean: {np.mean(uplift):.3f}')\n",
    "    axes[i].axvline(0, color='black', linewidth=0.5)\n",
    "    axes[i].set_xlabel('Predicted Uplift')\n",
    "    axes[i].set_ylabel('Density')\n",
    "    axes[i].set_title(f'{name} — Uplift Distribution')\n",
    "    axes[i].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Targeting Simulation: Personalized Treatment"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate targeting: treat only top X% by predicted uplift\n",
    "def simulate_targeting(uplift, T, Y, targeting_fraction=0.3):\n",
    "    \"\"\"Simulate benefit of targeting top fraction by uplift.\"\"\"\n",
    "    n = len(uplift)\n",
    "    n_treat = int(n * targeting_fraction)\n",
    "    \n",
    "    # Top fraction by predicted uplift\n",
    "    top_idx = np.argsort(uplift)[-n_treat:]\n",
    "    \n",
    "    # If we treat them:\n",
    "    treated_outcome = Y[top_idx].mean()\n",
    "    \n",
    "    # If we treat random:\n",
    "    random_idx = np.random.choice(n, n_treat, replace=False)\n",
    "    random_outcome = Y[random_idx].mean()\n",
    "    \n",
    "    # If we treat everyone:\n",
    "    full_treated = Y[T==1].mean() if T.sum() > 0 else 0\n",
    "    full_control = Y[T==0].mean() if (1-T).sum() > 0 else 0\n",
    "    \n",
    "    return {\n",
    "        'targeted_treated': treated_outcome,\n",
    "        'random_treated': random_outcome,\n",
    "        'full_treated': full_treated,\n",
    "        'full_control': full_control,\n",
    "        'uplift_gain': treated_outcome - random_outcome,\n",
    "    }\n",
    "\n",
    "print(\"Targeting simulation (treat top 30%):\")\n",
    "for name, uplift in uplift_preds.items():\n",
    "    sim = simulate_targeting(uplift, T_test, Y_test, 0.3)\n",
    "    print(f\"  {name}: Targeted={sim['targeted_treated']:.4f}, Random={sim['random_treated']:.4f}\n",
    "          Gain={sim['uplift_gain']:.4f}\")"
   ]
  },
 ],
