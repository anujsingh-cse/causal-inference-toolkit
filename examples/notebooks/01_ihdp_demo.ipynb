{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Causal Inference Toolkit — Demo: IHDP\n",
    "\n",
    "## Infant Health and Development Program (IHDP) Benchmark\n",
    "\n",
    "This notebook demonstrates the causal-toolkit on the IHDP dataset — a semi-synthetic benchmark for causal inference with known ground truth ATE.\n",
    "\n",
    "**Dataset**: 747 children (139 treated, 608 control) with 25 covariates.\nTreatment: high-quality childcare. Outcome: cognitive test score.\n\n**Ground truth ATE**: 4.0 (by construction in the simulated versions)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../../src')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "from causal_toolkit import (\n",
    "    CausalModel,\n",
    "    DoWhyWrapper,\n",
    "    EconMLWrapper,\n",
    "    SensitivityAnalyzer,\n",
    "    ABTestAnalyzer,\n",
    "    UpliftModeler,\n",
    "    ForestPlot,\n",
    "    LovePlot,\n",
    "    evaluate_uplift,\n",
    ")\n",
    "from causal_toolkit.core.base import EstimatorType, IdentificationStrategy, RefutationMethod\n",
    "from causal_toolkit.utils.data import load_dataset, create_synthetic_data\n",
    "\n",
    "np.random.seed(42)\n",
    "sns.set_style('whitegrid')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load IHDP dataset (replication 1 of 1000)\n",
    "df = load_dataset('ihdp', replication=1)\n",
    "print(f'Data shape: {df.shape}')\n",
    "print(f'Treatment balance: {df[\"treatment\"].mean():.2%}')\n",
    "print(f'Outcome mean: {df[\"outcome\"].mean():.3f}')\n",
    "print(f'True ATE: {df[\"true_cate\"].mean():.3f}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define variables\n",
    "treatment = 'treatment'\n",
    "outcome = 'outcome'\n",
    "confounders = [c for c in df.columns if c not in [treatment, outcome, 'true_cate']]\n",
    "print(f'Number of confounders: {len(confounders)}')\n",
    "print(f'Confounders: {confounders[:5]}...')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. DoWhy: Identification → Estimation → Refutation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build causal model\n",
    "model = CausalModel(\n",
    "    data=df,\n",
    "    treatment=treatment,\n",
    "    outcome=outcome,\n",
    "    common_causes=confounders,\n",
    ")\n",
    "\n",
    "# Create DoWhy wrapper\n",
    "dowhy = DoWhyWrapper(model)\n",
    "\n",
    "# Identify using backdoor criterion\n",
    "estimand = dowhy.identify(strategy=IdentificationStrategy.BACKDOOR)\n",
    "print(f'Estimand: {estimand}')\n",
    "print(f'Adjustment set: {estimand.adjustment_set}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Estimate ATE with linear regression\n",
    "est = dowhy.estimate(EstimatorType.LINEAR_REGRESSION)\n",
    "print(f'ATE Estimate: {est.value:.4f}')\n",
    "print(f'95% CI: [{est.ci_lower:.4f}, {est.ci_upper:.4f}]')\n",
    "print(f'True ATE: {df[\"true_cate\"].mean():.4f}')\n",
    "print(f'Bias: {est.value - df[\"true_cate\"].mean():.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Refutation tests\n",
    "refutations = dowhy.refute([\n",
    "    RefutationMethod.PLACEBO_TREATMENT,\n",
    "    RefutationMethod.RANDOM_COMMON_CAUSE,\n",
    "    RefutationMethod.DATA_SUBSET,\n",
    "    RefutationMethod.SIMULATED_CONFOUNDER,\n",
    "])\n",
    "for r in refutations:\n",
    "    print(r)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Sensitivity Analysis (Cinelli-Hazlett, Rosenbaum, E-value)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run full sensitivity suite\n",
    "analyzer = SensitivityAnalyzer(model)\n",
    "\n",
    "# Rosenbaum bounds (for binary treatment after matching/weighting)\n",
    "rosenbaum = analyzer.rosenbaum_bounds(est, gamma_range=(1.0, 3.0))\n",
    "print(rosenbaum)\n",
    "\n",
    "# Cinelli-Hazlett (for linear models)\n",
    "ch = analyzer.cinelli_hazlett(est)\n",
    "print(ch)\n",
    "\n",
    "# E-value\n",
    "evalue = analyzer.e_value(est)\n",
    "print(evalue)\n",
    "\n",
    "# Summary\n",
    "print(analyzer.summarize())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. EconML: Heterogeneous Treatment Effects (CATE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# EconML wrapper for CATE estimation\n",
    "econml = EconMLWrapper(\n",
    "    data=df,\n",
    "    treatment=treatment,\n",
    "    outcome=outcome,\n",
    "    covariates=confounders,\n",
    ")\n",
    "\n",
    "# Causal Forest (non-parametric CATE)\n",
    "cate_est = econml.estimate_cate(EstimatorType.CAUSAL_FOREST_CATE)\n",
    "print(f'CATE mean: {np.mean(cate_est.value):.4f}')\n",
    "print(f'CATE std: {np.std(cate_est.value):.4f}')\n",
    "\n",
    "# Compare with true CATE\n",
    "true_cate = df['true_cate'].values\n",
    "pred_cate = cate_est.value\n",
    "corr = np.corrcoef(true_cate, pred_cate)[0, 1]\n",
    "print(f'Correlation with true CATE: {corr:.4f}')\n",
    "mse = np.mean((pred_cate - true_cate) ** 2)\n",
    "print(f'MSE vs true CATE: {mse:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize CATE estimates vs truth\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "axes[0].scatter(true_cate, pred_cate, alpha=0.5)\n",
    "axes[0].plot([true_cate.min(), true_cate.max()],\n",
    "           [true_cate.min(), true_cate.max()], 'r--', label='y=x')\n",
    "axes[0].set_xlabel('True CATE')\n",
    "axes[0].set_ylabel('Predicted CATE')\n",
    "axes[0].set_title(f'CATE Correlation: {corr:.3f}')\n",
    "axes[0].legend()\n",
    "\n",
    "axes[1].hist(pred_cate, bins=30, alpha=0.7, label='Predicted', density=True)\n",
    "axes[1].hist(true_cate, bins=30, alpha=0.7, label='True', density=True)\n",
    "axes[1].set_xlabel('CATE')\n",
    "axes[1].set_ylabel('Density')\n",
    "axes[1].set_title('CATE Distributions')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Uplift Modeling"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Uplift modeling\n",
    "uplift_modeler = UpliftModeler(df, treatment, outcome, confounders)\n",
    "uplift_modeler.fit(method='causal_forest')\n",
    "\n",
    "uplift = uplift_modeler.predict_uplift()\n",
    "metrics = uplift_modeler.evaluate(df[confounders].values, df[treatment].values, df[outcome].values)\n",
    "print('Uplift Metrics:', metrics)\n",
    "\n",
    "# Qini curve\n",
    "fig = uplift_modeler.plot_qini(df[confounders].values, df[treatment].values, df[outcome].values)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Covariate Balance (Love Plot)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute SMDs before adjustment\n",
    "from causal_toolkit.utils.preprocessing import compute_all_smds\n",
    "\n",
    "smds = compute_all_smds(df, treatment, confounders)\n",
    "print('SMDs before adjustment:')\n",
    "for cov, res in list(smds.items())[:10]:\n",
    "    print(f'  {cov}: {res[\"smd\"]:.3f} (balanced: {res[\"balanced\"]})')\n",
    "\n",
    "# Love plot\n",
    "love = LovePlot()\n",
    "fig = love.plot(smds, threshold=0.1)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Compare Multiple Estimators"
   ]
  ],
